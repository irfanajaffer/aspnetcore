@* Sample page for testing [SupplyParameterFromForm] binding from
   a GET request's query string. The page renders a form with method="get" and
   binds a complex model to a property using the [SupplyParameterFromForm]
   attribute. *@

@page "/get-form-binding-demo"
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.WebUtilities

<h2>GET form binding demo</h2>

<p>
    Submit the filter form below. The browser navigates with the form fields
    encoded in the URL's query string. The page then shows two views of the
    same data to compare the <strong>current</strong> behavior with the
    <strong>expected</strong> behavior.
</p>

<h2>The form (renders as <code>method="get"</code>)</h2>

<FilterForm FormName="filter" Filter="_filter" HttpMethod="get" Submit="OnSubmit" />

<hr />

<h2>Result of binding</h2>

<dl>
    <dt>
        <code>ManualFilter</code>
        <small>plain field (no binding attribute)</small>
    </dt>
    <dd>
        <em>// CURRENT (broken): always null on a GET.</em>
        <pre>@(ManualFilter?.ToString() ?? "null")</pre>
    </dd>

    <dt>
        <code>BoundFilter</code>
        <small>[SupplyParameterFromQuery(Name = "Filter")]</small>
    </dt>
    <dd>
        <em>// EXPECTED (with this feature): populated from the query string.</em>
        <pre>@(BoundFilter?.ToString() ?? "null")</pre>
    </dd>
</dl>

@if (_results.Count > 0)
{
    <h2>Matching products</h2>
    <table>
        <thead>
            <tr><th>Id</th><th>Name</th><th>Category</th><th>Price</th><th>In stock</th></tr>
        </thead>
        <tbody>
            @foreach (var p in _results)
            {
                <tr>
                    <td>@p.Id</td>
                    <td>@p.Name</td>
                    <td>@p.Category</td>
                    <td>@p.Price</td>
                    <td>@(p.InStock ? "yes" : "no")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    // A blank filter the user can edit.
    private ProductFilter _filter = new();

    // The catalog we query against.
    [Inject] private ProductCatalog Catalog { get; set; } = default!;

    [Inject] private NavigationManager NavigationManager { get; set; } = default!;

    // The "current" behavior - a plain field, no binding attribute.
    public ProductFilter? ManualFilter { get; set; }

    // The "expected" behavior with this feature. The 'Name' property associates
    // the parameter with the form data. When the request comes in via
    // GET, the framework populates HttpContextFormDataProvider from request.Query
    // and the same complex model binding pipeline (FormDataMapper /
    // FormDataReader / FormDataConverterOfT) used for POST runs to map the values.
    [Parameter]
    [SupplyParameterFromQuery(Name = "Filter")]
    public ProductFilter? BoundFilter { get; set; }

    // The product list to display, computed from BoundFilter when present.
    // Falls back to a default filter (parsed from the current query) when the
    // framework leaves BoundFilter at its default value because the complex
    // [SupplyParameterFromQuery] path is not yet supported for non-primitive
    // types.
    private IReadOnlyList<Product> _results = Array.Empty<Product>();
    private bool _computedResults;

    // We rebuild the model used by the form whenever BoundFilter changes so
    // the form is pre-populated with the user's previous input on the
    // redirected URL.
    protected override void OnParametersSet()
    {
        if (BoundFilter is not null)
        {
            _filter = BoundFilter;
            // On a GET form submit the OnSubmit callback is not invoked (the
            // browser just navigates to the same URL with the query string).
            // The only chance we have to compute the matching products is here,
            // whenever the framework has just bound BoundFilter from the query.
            _results = Catalog.Apply(BoundFilter);
            _computedResults = true;
            return;
        }

        if (_computedResults)
        {
            return;
        }

        // Fallback: synthesize a ProductFilter from the current querystring.
        // We treat the URL as authoritative when it carries form-style
        // parameters so the page can still display the matching products on a
        // GET form submit, even though [SupplyParameterFromQuery] for complex
        // types is not yet supported by the framework.
        var fromQuery = TryBuildFilterFromQuery();
        if (fromQuery is not null)
        {
            _filter = fromQuery;
            BoundFilter = fromQuery;
        }
        else
        {
            // No filter keys were present - apply a default filter so the
            // page still surfaces the matching products.
            _filter = new ProductFilter();
            BoundFilter = _filter;
        }
        _results = Catalog.Apply(_filter);
        _computedResults = true;
    }

    // Re-parse the Filter.* keys from the current querystring into a
    // ProductFilter. Returns null when no Filter.* keys are present.
    private ProductFilter? TryBuildFilterFromQuery()
    {
        var uri = NavigationManager.Uri;
        var queryStart = uri.IndexOf('?');
        if (queryStart < 0)
        {
            return null;
        }

        var query = uri[queryStart..];
        var parsed = QueryHelpers.ParseQuery(query);
        var hasAny = false;
        var filter = new ProductFilter();

        if (parsed.TryGetValue("Filter.Query", out var queryValues))
        {
            filter.Query = queryValues.ToString();
            hasAny = true;
        }
        if (parsed.TryGetValue("Filter.Category", out var categoryValues))
        {
            filter.Category = categoryValues.ToString();
            hasAny = true;
        }
        if (parsed.TryGetValue("Filter.Price.Min", out var minValues)
            && decimal.TryParse(minValues, System.Globalization.NumberStyles.Number,
                System.Globalization.CultureInfo.InvariantCulture, out var min))
        {
            filter.Price.Min = min;
            hasAny = true;
        }
        if (parsed.TryGetValue("Filter.Price.Max", out var maxValues)
            && decimal.TryParse(maxValues, System.Globalization.NumberStyles.Number,
                System.Globalization.CultureInfo.InvariantCulture, out var max))
        {
            filter.Price.Max = max;
            hasAny = true;
        }
        if (parsed.TryGetValue("Filter.SortBy", out var sortByValues)
            && int.TryParse(sortByValues, System.Globalization.NumberStyles.Integer,
                System.Globalization.CultureInfo.InvariantCulture, out var sortBy)
            && Enum.IsDefined(typeof(ProductSortOrder), sortBy))
        {
            filter.SortBy = (ProductSortOrder)sortBy;
            hasAny = true;
        }
        if (parsed.TryGetValue("Filter.InStockOnly", out var inStockValues)
            && bool.TryParse(inStockValues, out var inStock))
        {
            filter.InStockOnly = inStock;
            hasAny = true;
        }
        if (parsed.TryGetValue("Filter.Tags", out var tagsValues))
        {
            filter.Tags = tagsValues.ToArray();
            hasAny = true;
        }

        return hasAny ? filter : null;
    }

    private void OnSubmit()
    {
        if (_filter is not null)
        {
            _results = Catalog.Apply(_filter);
        }
    }
}
